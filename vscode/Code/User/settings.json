{
    "@azure.argTenant": "",
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "claudeCode.preferredLocation": "panel",
    "docker.extension.enableComposeLanguageServer": false,
    "dotnetAcquisitionExtension.allowInvalidPaths": true,
    "dotnetAcquisitionExtension.existingDotnetPath": [
        {
            "extensionId": "ms-dotnettools.csharp",
            "path": "/home/linuxbrew/.linuxbrew/opt/dotnet/libexec/dotnet"
        }
    ],
    "dotnetAcquisitionExtension.sharedExistingDotnetPath": "/home/linuxbrew/.linuxbrew/opt/dotnet/libexec/dotnet",
    "editor.guides.bracketPairs": true,
    "files.autoSave": "afterDelay",
    "git.autofetch": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "print.folder.exclude": [
        "{bin,obj,out}",
        "node_modules",
        "data",
        "**/*.{bin,exe,dll,hex,pdb,pdf,pfx,png,jpg,gif,bmp,suo,design}"
    ],
    "print.folder.fileNames": true,
    "print.folder.include": [],
    "print.folder.includeFileList": false,
    "print.folder.maxFiles": 30,
    "print.folder.maxLines": 1200,
    "workbench.activityBar.location": "top",
    "workbench.iconTheme": "catppuccin-latte",
    "editor.minimap.size": "fill",
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "workbench.colorTheme": "Solarized Light",
    "notebook.lineNumbers": "on",
    "[gdscript]": {
        "editor.defaultFormatter": "geequlim.godot-tools"
    },
    "zig.zls.enabled": "on",
    "go.toolsManagement.autoUpdate": true,
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.chat.backgroundCompaction": true,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.chat.copilotMemory.enabled": true,
    "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
    "github.copilot.chat.alternateGptPrompt.enabled": true,
    "github.copilot.chat.anthropic.contextEditing.mode": "clear-both",
    "github.copilot.chat.anthropic.tools.websearch.enabled": true,
    "github.copilot.chat.completionsFetcher": "node-fetch",
    "github.copilot.chat.newWorkspace.useContext7": true,
    "github.copilot.chat.switchAgent.enabled": true,
    "github.copilot.chat.languageContext.inline.typescript.enabled": true,
    "github.copilot.chat.languageContext.typescript.enabled": true,
    "inlineChat.enableV2": true,
    "inlineChat.affordance": "editor",
    "inlineChat.notebookAgent": true,
    "inlineChat.renderMode": "hover",
    "inlineChat.defaultModel": "Auto (copilot)",
    "workbench.browser.enableChatTools": true,
    "git.blame.editorDecoration.enabled": true,
    "git.blame.editorDecoration.disableHover": true,
    "remote.SSH.localServerDownload": "always"
}